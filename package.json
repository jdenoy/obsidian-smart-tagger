{
  "name": "obsidian-smart-tagger",
  "version": "1.2.2",
  "description": "An Obsidian plugin that uses AI to automatically generate and match relevant tags for your notes",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": ["obsidian", "plugin", "ai", "tags", "chatgpt", "claude", "smart-tagger"],
  "author": "Johan Denoyer",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",

    "esbuild": "0.28.1",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "openai": "^4.0.0"
  }
}